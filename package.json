{
  "name": "sparkflow",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --parallel --filter \"./apps/*\" dev",
    "dev:backend": "pnpm --parallel --filter \"./apps/api-gateway\" --filter \"./apps/identity-service\" --filter \"./apps/challenge-service\" --filter \"./apps/submission-service\" --filter \"./apps/notification-service\" dev",
    "build": "pnpm --recursive --filter \"./tooling/*\" --filter \"./packages/*\" --filter \"./apps/*\" build",
    "commitlint": "commitlint --from HEAD~1 --to HEAD --verbose",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm --recursive --filter \"./tooling/*\" --filter \"./packages/*\" --filter \"./apps/*\" typecheck",
    "test": "pnpm --recursive --filter \"./tooling/*\" --filter \"./packages/*\" --filter \"./apps/*\" test",
    "infra:up": "docker compose -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@sparkflow/prettier-config": "workspace:*",
    "@types/node": "catalog:",
    "husky": "catalog:",
    "lint-staged": "catalog:",
    "prettier": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "packageManager": "pnpm@10.13.1"
}
